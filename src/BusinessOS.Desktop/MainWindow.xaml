<Window
    x:Class="BusinessOS.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="BusinessOS">
    <Grid Padding="32" RowSpacing="24" AutomationProperties.Name="BusinessOS main window">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="8" AutomationProperties.Name="BusinessOS header">
            <TextBlock Text="{Binding Title}" FontSize="32" FontWeight="SemiBold" AutomationProperties.Name="BusinessOS" />
            <TextBlock Text="{Binding Version}" FontSize="14" AutomationProperties.Name="BusinessOS application version" />
        </StackPanel>

        <Border Grid.Row="1" Padding="24" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" AutomationProperties.Name="Foundation content area">
            <StackPanel Spacing="12" MaxWidth="720" HorizontalAlignment="Left" VerticalAlignment="Top">
                <TextBlock Text="{Binding FoundationHeading}" FontSize="22" FontWeight="SemiBold" AutomationProperties.Name="Foundation" />
                <TextBlock Text="{Binding StatusMessage}" FontSize="18" TextWrapping="Wrap" AutomationProperties.Name="Fundament aplikacji został uruchomiony" />
                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" AutomationProperties.Name="Minimalny shell desktopowy gotowy na kolejne bloki BusinessOS." />
            </StackPanel>
        </Border>
    </Grid>
</Window>
